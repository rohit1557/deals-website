// Prisma schema — deals aggregator
// Run `npx prisma migrate dev` to apply pending migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// agent_memory
// Stores persistent key/value memory per agent.
// created_at added via migration 20240101000000 — required by Finn's Claude
// API cost estimator for time-series cost queries.
// ---------------------------------------------------------------------------
model AgentMemory {
  agentName String   @map("agent_name")
  key       String
  value     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@id([agentName, key])
  @@map("agent_memory")
}

// ---------------------------------------------------------------------------
// Deal
// Core deals table. category is a plain text field (not a FK — see roadmap
// for proper Category model). Decimal fields use @db.Decimal to ensure
// Prisma returns Decimal objects; always call toNumber() before serialising.
// ---------------------------------------------------------------------------
model Deal {
  id            String    @id @default(uuid()) @db.Uuid
  title         String
  description   String?
  url           String
  imageUrl      String?   @map("image_url")
  originalPrice Decimal?  @map("original_price") @db.Decimal(10, 2)
  dealPrice     Decimal?  @map("deal_price") @db.Decimal(10, 2)
  currency      String    @default("USD")
  discountPct   Int?      @map("discount_pct")
  category      String?
  source        String?
  expiresAt     DateTime? @map("expires_at") @db.Timestamptz
  isActive      Boolean?  @map("is_active")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime? @updatedAt @map("updated_at") @db.Timestamptz

  @@map("deals")
}
