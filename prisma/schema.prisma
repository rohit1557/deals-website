// This is your Prisma schema file.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Deals
// ---------------------------------------------------------------------------

model Deal {
  id            String    @id @default(uuid()) @db.Uuid
  title         String
  description   String?
  url           String
  imageUrl      String?   @map("image_url")
  originalPrice Decimal?  @map("original_price") @db.Decimal
  dealPrice     Decimal?  @map("deal_price")     @db.Decimal
  currency      String    // required — enforced on frontend via PR #16
  discountPct   Int?      @map("discount_pct")
  // NOTE: category is a plain text column, not a FK relation.
  // Needs a proper Category model + FK if we want categories.list to be clean.
  category      String?
  source        String?
  expiresAt     DateTime? @map("expires_at")
  isActive      Boolean?  @map("is_active")
  createdAt     DateTime? @map("created_at")
  updatedAt     DateTime? @map("updated_at")

  @@map("deals")
}

// ---------------------------------------------------------------------------
// Agent Memory
// ---------------------------------------------------------------------------

model AgentMemory {
  agentName String   @map("agent_name")
  key       String
  value     String
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz
  // created_at added via migration 20250721120000_add_agent_memory_created_at
  // Column was missing — caused 5 consecutive Vercel build failures (PR #32).
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@id([agentName, key])
  @@map("agent_memory")
}
