// Prisma schema for deals aggregator
// DB: Neon Postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Deal {
  id            String    @id @default(uuid()) @db.Uuid
  title         String
  description   String?
  url           String
  imageUrl      String?   @map("image_url")
  originalPrice Decimal?  @map("original_price") @db.Decimal(10, 2)
  dealPrice     Decimal?  @map("deal_price")     @db.Decimal(10, 2)
  // currency is required — must match the merchant's actual currency (e.g. "AUD", "USD").
  // Defaults to "USD" for legacy rows; scraper must supply this going forward.
  currency      String    @default("USD")
  discountPct   Int?      @map("discount_pct")
  // category is a plain text column for now. TODO: migrate to Category FK.
  category      String?
  source        String?
  expiresAt     DateTime? @map("expires_at")
  isActive      Boolean?  @default(true) @map("is_active")
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  @@index([category])
  @@index([createdAt])
  @@index([isActive])
  @@map("deals")
}
